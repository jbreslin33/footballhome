# Build outputs
build/
*.o
*.so
*.a

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Dynamic Docker compose files
docker-compose.override.yml

# Temporary working files
lighthouse_*.txt
*_extraction.txt

# Docker data
/docker/data/

# Post media (images/videos are disposable after posting to Instagram)
frontend/images/posts/

# Database backups (pg_dump snapshots)
backups/
# WireGuard provider config — plaintext is gitignored;
# encrypted scrape-vpn.conf.age IS committed and decrypted at setup time.
scrape-vpn.conf
# APSL login credentials — plaintext is gitignored;
# encrypted apsl-credentials.conf.age IS committed and decrypted at setup time.
apsl-credentials.conf
# Generated COPY format SQL files (created from INSERT SQL for fast loading)
database/data/*.copy.sql
database/data/99-*.sql

# App-generated data files (User/Dev and Production)
# database/data/*u-*-app.sql
# database/data/*p-*-app.sql

# Downloaded team logos (regenerated on scrape)
frontend/images/teams/logos/*.png
frontend/images/teams/logos/*.jpg
frontend/images/teams/logos/*.jpeg

# Downloaded player headshots (regenerated on scrape)
frontend/images/players/headshots/*.png
frontend/images/players/headshots/*.jpg
frontend/images/players/headshots/*.jpeg

# Node.js dependencies
node_modules/
package-lock.json

# Environment and credentials
.groupme-cookies.json
# Certificate and private key files
config/*.p12
config/*.pem
footballhome-git-crypt.key.env
# Plaintext env (decrypted from env.age by setup-age.sh) — never commit
/env
/env.backup.local
.aider*
# frontend/vendor/ is tracked - vis-network library needed for schema viewer
# Large binary files from roster scraping
*.xlsx
sync.log
.env
