# Host nginx vhost for one developer slot.
# Generated by: sudo make dev-nginx DEV=<slug>
# Requires DNS: <HOST_PREFIX>.dev.footballhome.org → this server
# Optional TLS: certbot --nginx -d <HOST_PREFIX>.dev.footballhome.org

server {
    listen 80;
    server_name __HOST_PREFIX__.dev.footballhome.org;

    client_max_body_size 100M;

    location /api/ {
        proxy_pass http://127.0.0.1:__BACKEND_PORT__;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    location / {
        proxy_pass http://127.0.0.1:__FRONTEND_PORT__;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
